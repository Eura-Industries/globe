rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users ────────────────────────────────────────────────────────────────
    match /users/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == uid;
    }

    // ── Boards ───────────────────────────────────────────────────────────────
    match /boards/{boardId} {
      // Helper: is the caller a collaborator?
      function isCollaborator() {
        return request.auth.uid in resource.data.collaborators.map(c, c.uid);
      }
      function isOwner() {
        return request.auth.uid == resource.data.ownerId;
      }

      // Read: owner or collaborator
      allow read: if request.auth != null && (isOwner() || isCollaborator());

      // Create: any authenticated user
      allow create: if request.auth != null
        && request.resource.data.ownerId == request.auth.uid;

      // Update: owner can change anything; collaborators cannot change ownerId
      allow update: if request.auth != null
        && (isOwner() ||
            (isCollaborator() && request.resource.data.ownerId == resource.data.ownerId));

      // Delete: owner only
      allow delete: if request.auth != null && isOwner();

      // ── Things (sub-collection) ───────────────────────────────────────────
      match /things/{thingId} {
        function boardData() {
          return get(/databases/$(database)/documents/boards/$(boardId)).data;
        }
        function canAccess() {
          return request.auth != null &&
            (request.auth.uid == boardData().ownerId ||
             request.auth.uid in boardData().collaborators.map(c, c.uid));
        }

        allow read, write: if canAccess();
      }
    }
  }
}
