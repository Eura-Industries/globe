# Copy this to .env and fill in real values for local development.
# These are also the environment variable names to set in your Vercel project.
# Never commit .env — it is gitignored.

# Firebase (required)
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=

# Firebase (optional)
FIREBASE_MEASUREMENT_ID=
FIREBASE_DATABASE_URL=

# Amadeus flight API (optional)
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
# AMADEUS_BASE_URL defaults to https://api.amadeus.com (prod) or https://test.api.amadeus.com (dev)
